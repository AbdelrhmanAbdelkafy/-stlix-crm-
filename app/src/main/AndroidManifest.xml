<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.StlixCrm"
        tools:targetApi="34">

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.HomeActivity" android:exported="false" />
        <activity android:name=".ui.ListActivity" android:exported="false" />
        <activity android:name=".ui.DetailActivity" android:exported="false" />
        <activity android:name=".ui.CreateActivity" android:exported="false" />
        <activity android:name=".ui.ActivitiesActivity" android:exported="false" />
    </application>
</manifest>
